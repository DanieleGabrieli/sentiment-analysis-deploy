{
  "title": "Sentiment Analysis API",
  "uid": "sentiment-api-dashboard",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(api_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P95 Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(api_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 3,
      "title": "Predictions by Sentiment",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "increase(predictions_by_sentiment_total[1h])",
          "legendFormat": "{{sentiment}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Prediction Errors",
      "type": "stat",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "prediction_errors_total",
          "legendFormat": "Total errors"
        }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "red",    "value": 10 }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "CPU Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 8, "w": 4, "h": 8 },
      "targets": [
        { "expr": "system_cpu_usage_percent", "legendFormat": "CPU" }
      ],
      "options": {
        "minValue": 0, "maxValue": 100,
        "thresholds": {
          "steps": [
            { "color": "green",  "value": 0  },
            { "color": "yellow", "value": 70 },
            { "color": "red",    "value": 90 }
          ]
        }
      }
    },
    {
      "id": 6,
      "title": "Memory Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 20, "y": 8, "w": 4, "h": 8 },
      "targets": [
        { "expr": "system_memory_usage_percent", "legendFormat": "Memory" }
      ],
      "options": {
        "minValue": 0, "maxValue": 100,
        "thresholds": {
          "steps": [
            { "color": "green",  "value": 0  },
            { "color": "yellow", "value": 70 },
            { "color": "red",    "value": 90 }
          ]
        }
      }
    }
  ]
}
